
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Reglas para todos los archivos en el bucket
    match /{allPaths=**} {
      
      // PERMISOS DE LECTURA
      // Permite la lectura a usuarios autenticados O a cualquier imagen.
      // Las fotos de perfil/miembro se cargan vía <img> en el navegador, cuyas
      // peticiones NO envían el token de auth de Firebase. Por eso las imágenes
      // deben ser legibles públicamente; con token de descarga ya lo eran, esto
      // evita el 403 cuando la URL no trae token.
      allow read: if request.auth != null || resource.contentType.matches('image/.*');

      // PERMISOS DE ESCRITURA (Crear, Actualizar, Eliminar)
      // Solo permite la escritura si se cumplen TODAS las siguientes condiciones:
      // 1. El usuario debe estar autenticado (request.auth != null).
      // 2. El tamaño del archivo debe ser menor a 20 MB.
      // 3. El tipo de contenido del archivo debe ser una imagen (ej: 'image/jpeg', 'image/png').
      allow write: if request.auth != null && (
                      request.resource == null ||
                      (
                        request.resource.size < 20 * 1024 * 1024 &&
                        request.resource.contentType.matches('image/.*')
                      )
                    );
    }
  }
}
